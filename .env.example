# ============================================================
# NEXUS Cloud-Native Microservices Platform
# Example Environment Configuration
# ============================================================
#
# Copy this file to a local file named:
#
# .env
#
# Then replace the placeholder values with local development
# values.
#
# Never commit the completed .env file to GitHub.
# ============================================================


# ------------------------------------------------------------
# Application Environment
# ------------------------------------------------------------

APP_NAME=NEXUS Cloud-Native Microservices Platform
APP_ENV=development
LOG_LEVEL=INFO
API_VERSION=v1


# ------------------------------------------------------------
# Frontend Configuration
# ------------------------------------------------------------

VITE_APP_NAME=NEXUS
VITE_API_BASE_URL=http://localhost:8080/api/v1


# ------------------------------------------------------------
# API Gateway Configuration
# ------------------------------------------------------------

API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8080

FRONTEND_ORIGIN=http://localhost:3000

REQUEST_BODY_LIMIT=1mb
REQUEST_TIMEOUT_MS=5000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX_REQUESTS=5


# ------------------------------------------------------------
# Identity Service Configuration
# ------------------------------------------------------------

IDENTITY_SERVICE_HOST=0.0.0.0
IDENTITY_SERVICE_PORT=8001
IDENTITY_SERVICE_URL=http://identity-service:8001

JWT_SECRET=replace-with-a-long-random-development-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

PASSWORD_MIN_LENGTH=12


# ------------------------------------------------------------
# Service Registry Configuration
# ------------------------------------------------------------

SERVICE_REGISTRY_HOST=0.0.0.0
SERVICE_REGISTRY_PORT=8002
SERVICE_REGISTRY_URL=http://service-registry:8002

HEALTH_CHECK_TIMEOUT_SECONDS=5
HEALTH_CHECK_MAX_REDIRECTS=3
HEALTH_CHECK_MAX_RESPONSE_BYTES=1048576

HEALTHY_RESPONSE_TIME_MS=500
DEGRADED_RESPONSE_TIME_MS=1500


# ------------------------------------------------------------
# Incident Service Configuration
# ------------------------------------------------------------

INCIDENT_SERVICE_HOST=0.0.0.0
INCIDENT_SERVICE_PORT=8003
INCIDENT_SERVICE_URL=http://incident-service:8003


# ------------------------------------------------------------
# Notification Service Configuration
# ------------------------------------------------------------

NOTIFICATION_SERVICE_HOST=0.0.0.0
NOTIFICATION_SERVICE_PORT=8004
NOTIFICATION_SERVICE_URL=http://notification-api:8004

NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_SECONDS=5


# ------------------------------------------------------------
# PostgreSQL Configuration
# ------------------------------------------------------------

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexus
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=replace-with-a-local-development-password

DATABASE_URL=postgresql://nexus_user:replace-with-a-local-development-password@postgres:5432/nexus


# ------------------------------------------------------------
# Service-Specific PostgreSQL Schemas
# ------------------------------------------------------------

IDENTITY_DATABASE_SCHEMA=identity
REGISTRY_DATABASE_SCHEMA=registry
INCIDENT_DATABASE_SCHEMA=incidents
NOTIFICATION_DATABASE_SCHEMA=notifications
AUDIT_DATABASE_SCHEMA=audit


# ------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

CELERY_DEFAULT_QUEUE=default
CELERY_NOTIFICATION_QUEUE=notifications
CELERY_HEALTH_CHECK_QUEUE=health_checks


# ------------------------------------------------------------
# Dashboard Cache Configuration
# ------------------------------------------------------------

DASHBOARD_CACHE_TTL_SECONDS=30
HEALTH_CHECK_LOCK_TTL_SECONDS=60


# ------------------------------------------------------------
# Demonstration Seed User Configuration
# ------------------------------------------------------------

DEMO_ADMIN_USERNAME=admin_demo
DEMO_ADMIN_EMAIL=admin@nexus.local
DEMO_ADMIN_PASSWORD=replace-with-a-development-password

DEMO_OWNER_USERNAME=owner_demo
DEMO_OWNER_EMAIL=owner@nexus.local
DEMO_OWNER_PASSWORD=replace-with-a-development-password

DEMO_ANALYST_USERNAME=analyst_demo
DEMO_ANALYST_EMAIL=analyst@nexus.local
DEMO_ANALYST_PASSWORD=replace-with-a-development-password

DEMO_VIEWER_USERNAME=viewer_demo
DEMO_VIEWER_EMAIL=viewer@nexus.local
DEMO_VIEWER_PASSWORD=replace-with-a-development-password


# ------------------------------------------------------------
# Prometheus Configuration
# ------------------------------------------------------------

PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_URL=http://prometheus:9090


# ------------------------------------------------------------
# Grafana Configuration
# ------------------------------------------------------------

GRAFANA_HOST=grafana
GRAFANA_PORT=3000
GRAFANA_URL=http://grafana:3000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-development-password


# ------------------------------------------------------------
# OpenTelemetry and Jaeger Configuration
# ------------------------------------------------------------

OTEL_SERVICE_NAME=nexus
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

JAEGER_HOST=jaeger
JAEGER_UI_PORT=16686
JAEGER_URL=http://jaeger:16686


# ------------------------------------------------------------
# Docker Compose Configuration
# ------------------------------------------------------------

COMPOSE_PROJECT_NAME=nexus

FRONTEND_HOST_PORT=3000
API_GATEWAY_HOST_PORT=8080
IDENTITY_SERVICE_HOST_PORT=8001
SERVICE_REGISTRY_HOST_PORT=8002
INCIDENT_SERVICE_HOST_PORT=8003
NOTIFICATION_SERVICE_HOST_PORT=8004

POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6379
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3001
JAEGER_UI_HOST_PORT=16686
JAEGER_OTLP_HOST_PORT=4317


# ------------------------------------------------------------
# Kubernetes Configuration
# ------------------------------------------------------------

KUBERNETES_NAMESPACE=nexus
KUBERNETES_INGRESS_HOST=nexus.local

FRONTEND_REPLICAS=1
API_GATEWAY_REPLICAS=2
IDENTITY_SERVICE_REPLICAS=2
SERVICE_REGISTRY_REPLICAS=2
INCIDENT_SERVICE_REPLICAS=2
NOTIFICATION_SERVICE_REPLICAS=1
NOTIFICATION_WORKER_REPLICAS=2
HEALTH_WORKER_REPLICAS=1


# ------------------------------------------------------------
# Security Configuration
# ------------------------------------------------------------

ALLOWED_ORIGINS=http://localhost:3000,http://nexus.local
ALLOWED_HOSTS=localhost,127.0.0.1,nexus.local

ENABLE_SECURE_HEADERS=true
ENABLE_RATE_LIMITING=true

HEALTH_CHECK_ALLOWED_SCHEMES=http,https
HEALTH_CHECK_ALLOW_LOCALHOST=false
HEALTH_CHECK_ALLOW_PRIVATE_NETWORKS=false


# ------------------------------------------------------------
# Testing Configuration
# ------------------------------------------------------------

TEST_POSTGRES_DB=nexus_test
TEST_REDIS_DB=2

TEST_DATABASE_URL=postgresql://nexus_user:replace-with-a-local-development-password@postgres:5432/nexus_test
TEST_REDIS_URL=redis://redis:6379/2

PLAYWRIGHT_BASE_URL=http://localhost:3000


# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------

ENABLE_SCHEDULED_HEALTH_CHECKS=true
ENABLE_NOTIFICATION_RETRIES=true
ENABLE_DASHBOARD_CACHE=true
ENABLE_AUDIT_LOGGING=true
ENABLE_METRICS=true
ENABLE_DISTRIBUTED_TRACING=true